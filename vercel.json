{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.3",
            "config": {
                "environment": {
                    "APP_NAME": "PT Wastu Cipta Nagara",
                    "APP_ENV": "production",
                    "APP_DEBUG": "false",
                    "APP_KEY": "base64:9vtXAWGmtGMB66mjiFNEnE7T+Wlnwg6F3AQr3+LBcKk=",
                    "APP_URL": "https://pt-wastu-cipta-nagara.vercel.app",
                    "LOG_CHANNEL": "stderr",
                    "SESSION_DRIVER": "cookie",
                    "SESSION_LIFETIME": "120",
                    "CACHE_STORE": "array",
                    "CACHE_DRIVER": "array",
                    "QUEUE_CONNECTION": "sync",
                    "FILESYSTEM_DISK": "public",
                    "DB_CONNECTION": "sqlite",
                    "DB_DATABASE": "/tmp/database.sqlite",
                    "VERCEL": "1"
                }
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
